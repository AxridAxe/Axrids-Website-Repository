rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kurtdolan2@gmail.com" || 
         request.auth.token.email == "kurtdolan2005@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['aboutText', 'instagramUrl', 'youtubeUrl', 'soundcloudUrl']) &&
             data.aboutText is string &&
             data.instagramUrl is string &&
             data.youtubeUrl is string &&
             data.soundcloudUrl is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'role']) &&
             data.email is string &&
             data.displayName is string &&
             data.displayName.size() < 100 &&
             data.role in ['admin', 'user'] &&
             (!('alias' in data) || (data.alias is string && data.alias.size() < 100));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['content', 'authorId', 'authorName', 'createdAt', 'isVisible']) &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 10000 &&
             data.isVisible is bool &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.authorName.size() < 100 &&
             (!('title' in data) || (data.title is string && data.title.size() < 200)) &&
             (!('subtitle' in data) || (data.subtitle is string && data.subtitle.size() < 200));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['content', 'authorId', 'authorName', 'createdAt']) &&
             data.content is string &&
             data.content.size() > 0 &&
             data.content.size() < 1000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.authorName.size() < 100 &&
             (!('authorPhoto' in data) || (data.authorPhoto is string && data.authorPhoto.size() < 500));
    }

    function isValidAlbum(data) {
      let requiredFields = ['title', 'trackIds', 'isVisible', 'createdAt', 'authorId'];
      let optionalFields = ['artist', 'coverUrl', 'releaseDate', 'description'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('artist' in data) || (data.artist is string && data.artist.size() < 200)) &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() < 1000)) &&
             (!('releaseDate' in data) || data.releaseDate is string) &&
             (!('description' in data) || data.description is string) &&
             data.trackIds is list && data.trackIds.size() <= 100 &&
             data.isVisible is bool &&
             data.authorId is string &&
             data.createdAt is timestamp;
    }

    function isValidTrack(data) {
      let requiredFields = ['title', 'artist', 'isVisible', 'createdAt', 'authorId'];
      let optionalFields = [
        'audioUrl', 'coverUrl', 'trackLink', 'genre', 'album', 'description', 'privacy',
        'buyLink', 'recordLabel', 'publisher', 'soundcloudUrl', 'isExplicit',
        'enableDirectDownloads', 'offlineListening', 'displayEmbedCode',
        'allowComments', 'showCommentsToPublic', 'licenseType', 'releaseDate',
        'deletedAt', 'bpm'
      ];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             (data.keys().hasAny(['audioUrl', 'soundcloudUrl'])) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.artist is string && data.artist.size() > 0 && data.artist.size() < 200 &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() < 1000)) &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() < 1000)) &&
             data.isVisible is bool &&
             data.authorId is string &&
             data.createdAt is timestamp &&
             (!('releaseDate' in data) || data.releaseDate is string) &&
             (!('deletedAt' in data) || data.deletedAt is timestamp) &&
             (!('trackLink' in data) || data.trackLink is string) &&
             (!('genre' in data) || data.genre is string) &&
             (!('album' in data) || data.album is string) &&
             (!('description' in data) || data.description is string) &&
             (!('privacy' in data) || data.privacy in ['public', 'private', 'scheduled']) &&
             (!('buyLink' in data) || data.buyLink is string) &&
             (!('recordLabel' in data) || data.recordLabel is string) &&
             (!('bpm' in data) || data.bpm is number) &&
             (!('publisher' in data) || data.publisher is string) &&
             (!('soundcloudUrl' in data) || data.soundcloudUrl is string) &&
             (!('isExplicit' in data) || data.isExplicit is bool) &&
             (!('enableDirectDownloads' in data) || data.enableDirectDownloads is bool) &&
             (!('offlineListening' in data) || data.offlineListening is bool) &&
             (!('displayEmbedCode' in data) || data.displayEmbedCode is bool) &&
             (!('allowComments' in data) || data.allowComments is bool) &&
             (!('showCommentsToPublic' in data) || data.showCommentsToPublic is bool) &&
             (!('licenseType' in data) || data.licenseType in ['all-rights-reserved', 'creative-commons']);
    }

    function isValidChangelog(data) {
      return data.keys().hasAll(['title', 'description', 'date', 'time', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.date is string &&
             data.time is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /posts/{postId} {
      allow get: if resource.data.isVisible == true || isAdmin();
      allow list: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow list: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
      }
    }

    match /albums/{albumId} {
      allow get: if resource.data.isVisible == true || isAdmin() || isOwner(resource.data.authorId);
      allow list: if true;
      allow create: if isAuthenticated() && isValidAlbum(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if (isAdmin() || isOwner(resource.data.authorId)) && 
                    isValidAlbum(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /tracks/{trackId} {
      allow get: if resource.data.isVisible == true || isAdmin() || isOwner(resource.data.authorId);
      allow list: if true;
      allow create: if isAuthenticated() && isValidTrack(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if (isAdmin() || isOwner(resource.data.authorId)) && 
                    isValidTrack(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid in resource.data.participants);
      allow list: if isAdmin() || isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.participants.size() == 2 &&
                    request.auth.uid in request.resource.data.participants;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow list: if isAdmin() || (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.content is string &&
                      request.resource.data.content.size() > 0 &&
                      request.resource.data.content.size() < 5000;
        allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId && request.resource.data.senderId == resource.data.senderId);
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId);
      }
    }

    match /changelog/{changelogId} {
      allow read: if true;
      allow create: if isAdmin() && isValidChangelog(request.resource.data);
      allow update: if isAdmin() && isValidChangelog(request.resource.data);
      allow delete: if isAdmin();
    }

    // Collection Group rule for Global Moderation
    match /{path=**}/comments/{commentId} {
      allow read: if isAuthenticated();
    }

    // Collection Group rule for Message Moderation
    // Restrict to admins only to prevent unauthorized message access.
    match /{path=**}/messages/{messageId} {
      allow read: if isAdmin();
    }
  }
}
